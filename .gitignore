## Ignore Visual Studio temporary files, build results, and user settings

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/ActiveWriter)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Ww]in32/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Log]s/
[Ff]igmaVisuals/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/

# VS Code settings
.vscode/

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, since NuGet usage there might be important
!**/[Pp]ackages/build/

# OS-specific files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
